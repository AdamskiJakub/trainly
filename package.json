{
  "name": "trainly-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Trainly - Marketplace for personal trainers and fitness instructors",
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"bgBlue.bold,bgMagenta.bold\" \"pnpm --filter backend start:dev\" \"pnpm --filter frontend dev\"",
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "db:migrate": "pnpm --filter backend prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter backend prisma migrate deploy",
    "db:generate": "pnpm --filter backend prisma generate",
    "db:studio": "pnpm --filter backend prisma studio",
    "db:reset": "pnpm --filter backend prisma migrate reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "install:all": "pnpm install && pnpm --filter backend install && pnpm --filter frontend install",
    "clean": "pnpm --filter backend clean && pnpm --filter frontend clean && rm -rf node_modules"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
